generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]
  artists       Artist[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Artist {
  id          String   @id @default(cuid())
  userId      String
  name        String
  genre       String   @default("Electronic / House")
  bio         String?
  email       String?
  instagram   String?
  tiktok      String?
  soundcloud  String?
  spotify     String?
  bookingFee  Float    @default(500)
  city        String   @default("Miami, FL")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  bookings    Booking[]
  contentItems ContentItem[]
  invoices    Invoice[]
  prCampaigns PrCampaign[]
  agentLogs   AgentLog[]
  weeklyBriefs WeeklyBrief[]
}

model Booking {
  id          String   @id @default(cuid())
  artistId    String
  promoter    String
  venue       String
  eventDate   DateTime
  fee         Float
  status      String   @default("inquiry") // inquiry | confirmed | completed | cancelled
  notes       String?
  contractUrl String?
  paidAt      DateTime?
  createdAt   DateTime @default(now())
  artist      Artist   @relation(fields: [artistId], references: [id])
}

model ContentItem {
  id          String   @id @default(cuid())
  artistId    String
  platform    String   // instagram | tiktok | both
  caption     String
  hook        String?
  hashtags    String?
  mediaType   String   @default("post") // post | reel | story
  status      String   @default("draft") // draft | scheduled | posted | rejected
  scheduledAt DateTime?
  postedAt    DateTime?
  source      String   @default("agent") // agent | manual
  createdAt   DateTime @default(now())
  artist      Artist   @relation(fields: [artistId], references: [id])
}

model Invoice {
  id          String   @id @default(cuid())
  artistId    String
  bookingId   String?
  client      String
  amount      Float
  status      String   @default("pending") // pending | sent | paid | overdue
  dueDate     DateTime
  sentAt      DateTime?
  paidAt      DateTime?
  remindersSent Int    @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  artist      Artist   @relation(fields: [artistId], references: [id])
}

model PrCampaign {
  id          String   @id @default(cuid())
  artistId    String
  release     String
  type        String   @default("single") // single | ep | album | event
  outreachList String  // JSON array of targets
  status      String   @default("active") // active | paused | completed
  sentCount   Int      @default(0)
  responseCount Int    @default(0)
  createdAt   DateTime @default(now())
  artist      Artist   @relation(fields: [artistId], references: [id])
  targets     PrTarget[]
}

model PrTarget {
  id          String   @id @default(cuid())
  campaignId  String
  name        String
  type        String   // blog | curator | radio | press
  email       String?
  pitchSent   Boolean  @default(false)
  sentAt      DateTime?
  responded   Boolean  @default(false)
  response    String?
  campaign    PrCampaign @relation(fields: [campaignId], references: [id])
}

model AgentLog {
  id          String   @id @default(cuid())
  artistId    String
  agentType   String   // booking | content | revenue | pr | intel
  action      String
  details     String?
  status      String   @default("success") // success | pending | error
  createdAt   DateTime @default(now())
  artist      Artist   @relation(fields: [artistId], references: [id])
}

model WeeklyBrief {
  id          String   @id @default(cuid())
  artistId    String
  weekOf      DateTime
  content     String   // full markdown brief from intel agent
  highlights  String   // JSON array of key points
  createdAt   DateTime @default(now())
  artist      Artist   @relation(fields: [artistId], references: [id])
}
